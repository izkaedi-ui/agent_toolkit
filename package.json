{
  "name": "agent-os-toolkit",
  "version": "0.1.0",
  "description": "Agent OS toolkit: protocol library, MCP animation toolkit, meta-orchestrator, scorecard, and self-test harness.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "orchestrate": "node agent-os/40_meta_orchestrator/meta-orchestrator.mjs",
    "orchestrate:super": "node agent-os/40_meta_orchestrator/supercharged-meta-orchestrator.mjs",
    "lint:protocols": "node agent-os/42_protocol_linter/protocol-linter.mjs",
    "self-test": "node agent-os/41_self_test_harness/SELF_TEST_RUNNER.mjs",
    "score": "node agent-os/48_agent_os_scorecard/score-agent-run.mjs",
    "validate:reports": "node agent-os/51_trust_pack/validate-agent-os-reports.mjs",
    "mcp:stdio": "node agent-os/52_mcp_transport/mcp-stdio-server.mjs",
    "benchmark:arena": "node agent-os/53_benchmark_arena/run-benchmark-arena.mjs",
    "release:trust": "node agent-os/54_release_trust/release-trust-check.mjs",
    "docs:index": "node agent-os/55_docs_site/generate-docs-index.mjs",
    "golden:verify": "node agent-os/56_golden_reports/verify-golden-reports.mjs",
    "mutation:test": "node agent-os/57_mutation_tests/run-mutation-tests.mjs",
    "schema:validate": "node agent-os/60_schema_validation/validate-report-schemas.mjs",
    "mcp:smoke": "node agent-os/59_mcp_compliance/mcp-client-smoke-test.mjs",
    "benchmark:arena:v2": "node agent-os/62_benchmark_arena_v2/benchmark-arena-v2.mjs",
    "viewer:generate": "node agent-os/65_report_viewer/generate-report-viewer.mjs",
    "package:check": "node agent-os/70_package_publishing/publishing-readiness-check.mjs",
    "evidence:manifest": "node agent-os/72_version_evidence_manifest/generate-version-evidence.mjs",
    "claim:diff": "node agent-os/73_claim_diff_engine/claim-diff.mjs",
    "proof:debt": "node agent-os/75_proof_debt_tracker/proof-debt-tracker.mjs",
    "release:manifest": "node agent-os/83_release_artifact_manifest/generate-release-artifact-manifest.mjs",
    "zkaedi:evidence": "node agent-os/84_zkaedi_model_evidence/verify-zkaedi-model-evidence.mjs",
    "verify:all": "npm run typecheck && npm run build && npm run orchestrate && npm run orchestrate:super && npm run lint:protocols && npm run self-test && npm run score && npm run validate:reports && npm run benchmark:arena && npm run benchmark:arena:v2 && npm run golden:verify && npm run mutation:test && npm run release:trust && npm run zkaedi:evidence && npm run schema:validate && npm run mcp:smoke && npm run package:check && npm run claim:diff && npm run proof:debt && npm run release:manifest && npm run evidence:manifest && npm run viewer:generate"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
